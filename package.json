{
  "name": "findgym",
  "version": "0.1.0",
  "private": true,
  "description": "Taiwan no-contract gym discovery app",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.mjs",
    "validate": "node scripts/validate-data.mjs data/gyms.json",
    "build:web": "node scripts/build-web.mjs",
    "sync": "npm run build:web && cap sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0"
  }
}
