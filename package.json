{
  "name": "findgym",
  "version": "0.1.0",
  "private": true,
  "description": "Taiwan no-contract gym discovery app",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.mjs",
    "validate": "node scripts/validate-data.mjs data/gyms.json",
    "build:web": "node scripts/build-web.mjs",
    "patch:ios": "node scripts/patch-ios.mjs",
    "patch:android": "node scripts/patch-android.mjs",
    "patch:native": "node scripts/patch-ios.mjs || true; node scripts/patch-android.mjs || true",
    "assets:native": "capacitor-assets generate --assetPath assets-src --ios --android",
    "sync": "npm run build:web && cap sync && npm run patch:native",
    "open:ios": "cap open ios",
    "open:android": "cap open android"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  }
}
